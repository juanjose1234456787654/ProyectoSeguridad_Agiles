# Puerto del microservicio MS-IDENTIDAD
PORT=4001

# Cliente de base de datos: "sqlserver" o "mysql"
DB_CLIENT=sqlserver

# SQL Server (instancia local con autenticación Windows)
DB_SQL_INSTANCE=localhost\SQLEXPRESS

# Nombres de las bases de datos
DB_IDENTIDAD_NAME=BD_IDENTIDAD
DB_UTA_NAME=BD_UTA

# MySQL (solo si DB_CLIENT=mysql)
# DB_HOST=localhost
# DB_USER=root
# DB_PASSWORD=tu_password
# DB_POOL_LIMIT=10

# Clave secreta para firmar los JWT (cámbiala por una clave segura)
JWT_SECRET=cambia_esta_clave_secreta_por_una_segura
